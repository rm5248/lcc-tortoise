	pinctrl-0 = <&usart1_tx_pc4 &usart1_rx_pc5>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};
*/


/*
&rtc {
	clocks = <&rcc STM32_CLOCK_BUS_APB1 0x00000400>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&iwdg {
	status = "okay";
};
*/

&spi1 {
	pinctrl-0 = <&spi1_sck_pb3
		     &spi1_miso_pb4 &spi1_mosi_pb5>;
	pinctrl-names = "default";
	status = "okay";

	cs-gpios = <&gpiob 6 GPIO_ACTIVE_LOW>,
                   <&gpiob 7 GPIO_ACTIVE_LOW>;

	gpio_expander: mcp23s08@0 {
		compatible = "microchip,mcp23s08";
		spi-max-frequency = <1000000>;
		reg = <0x0>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <8>;
		reset-gpios = <&gpioa 8 GPIO_ACTIVE_LOW>;
	};
	gpio_expander2: mcp23s08@1 {
		compatible = "microchip,mcp23s08";
		spi-max-frequency = <1000000>;
		reg = <0x1>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <8>;
		reset-gpios = <&gpioa 8 GPIO_ACTIVE_LOW>;
	};
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* We have 512k of flash, so let's not worry too much about space */
		boot_partition: partition@0 {
			label = "bootloader";
			reg = <0x00000000 DT_SIZE_K(48)>;
			read-only;
		};
		slot0_partition: partition@C000 {
			label = "image-0";
			reg = <0x0000C000 DT_SIZE_K(232)>;
		};
		slot1_partition: partition@46000 {
			label = "image-1";
			reg = <0x00046000 DT_SIZE_K(232)>;
		};
	};
};

&fdcan2 {
	clocks = <&rcc STM32_CLOCK_BUS_APB1 0x00001000>,
		 <&rcc STM32_SRC_PLL_Q FDCAN_SEL(1)>;
	pinctrl-0 = <&fdcan2_rx_pb0 &fdcan2_tx_pb1>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c2 {
	pinctrl-0 = <&i2c2_scl_pa9 &i2c2_sda_pa10>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	gpio_in0: tca9538@38 {
		compatible = "ti,tca9538";
		reg = <0x38>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <8>;
		nint-gpios = <&gpioa 11 GPIO_ACTIVE_LOW>;
	};

	gpio_in1: tca9538@39 {
		compatible = "ti,tca9538";
		reg = <0x39>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <8>;
		nint-gpios = <&gpioa 12 GPIO_ACTIVE_LOW>;
	};
};
