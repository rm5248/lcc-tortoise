/dts-v1/;
#include <st/g0/stm32g0b1Xe.dtsi>
#include <st/g0/stm32g0b1k(b-c-e)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl-common.h>

/* CPU: STM32G0B1KE
 * FLASH: 512k
 * SRAM: 128(parity-protected)/144(not parity-protected)
 */

/ {
	model = "io32-plus";
	compatible = "st,stm32g0b1ke-smtc8";

	chosen {
		zephyr,console = &usart2;
		zephyr,shell-uart = &usart2;
		zephyr,uart-mcumgr = &usart2;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,canbus = &fdcan2;
	};

	aliases {
		greenled = &green_led;
		blueled = &blue_led;
		goldled = &gold_led;
		blueswitch = &blue_switch;
		gpioreset = &gpio_exp_reset;
	};

	zephyr,user {
		output-gpios = <&gpio_expander 0 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 1 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 2 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 3 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 4 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 5 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 6 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander 7 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 0 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 1 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 2 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 3 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 4 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 5 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 6 GPIO_ACTIVE_HIGH>,
		         <&gpio_expander2 7 GPIO_ACTIVE_HIGH>;

		input-gpios = <&gpio_in0 0 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 1 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 2 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 3 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 4 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 5 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 6 GPIO_ACTIVE_HIGH>,
				<&gpio_in0 7 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 0 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 1 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 2 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 3 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 4 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 5 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 6 GPIO_ACTIVE_HIGH>,
				<&gpio_in1 7 GPIO_ACTIVE_HIGH>;
	};

	leds: leds {
		compatible = "gpio-leds";
		green_led: led_g {
			gpios = <&gpioc 6 GPIO_ACTIVE_HIGH>;
			label = "Green LED";
		};
		blue_led: led_b {
			gpios = <&gpiob 8 GPIO_ACTIVE_HIGH>;
			label = "Blue LED";
		};
		gold_led: led_gl {
			gpios = <&gpiob 9 GPIO_ACTIVE_HIGH>;
			label = "Gold LED";
		};

		gpio_exp_reset: foo {
			gpios = <&gpioa 8 GPIO_ACTIVE_HIGH>;
		};
	};

	gpio_keys {
		compatible = "gpio-keys";
		blue_switch: button_blue {
			label = "blue_switch";
			gpios = <&gpioa 5 (GPIO_ACTIVE_LOW)>;
		};
		gold_switch: button_gold {
			label = "gold_switch";
			gpios = <&gpioa 14 (GPIO_ACTIVE_HIGH)>;
		};
	};
};

/*
&clk_lsi {
	status = "okay";
};

&clk_hsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
	crs-usb-sof;
};
*/

&clk_hse {
	status = "okay";
	hse-bypass;
	clock-frequency = <DT_FREQ_M(8)>;
};

&pll {
	div-m = <1>;
	mul-n = <16>;
	div-p = <2>;
	div-q = <2>;
	div-r = <4>;
	clocks = <&clk_hse>;
	status = "okay";
};


&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(32)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
};


/*
zephyr_udc0: &usb {
	pinctrl-0 = <&usb_dm_pa11 &usb_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};
*/

